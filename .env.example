# Copie para .env.local e preencha para ativar o pagamento real (Mercado Pago · Pix).
# Sem esta variável, o botão de compra fica em modo reserva (sem cobrança).
# Pegue o token em: mercadopago.com.br -> Suas integracoes -> Credenciais.
# Cadastre tambem uma CHAVE PIX na sua conta (e onde o dinheiro cai).
# Comece com o token de TESTE para validar sem cobrar de verdade.
MP_ACCESS_TOKEN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Numero do WhatsApp de atendimento (formato internacional, so digitos: 55 + DDD + numero).
# Usado no link "conversar" do rodape. Fica so no .env.local (fora do codigo versionado).
NEXT_PUBLIC_WHATSAPP_NUMBER=
